{
  "expo": {
    "name": "CostView",
    "slug": "costview",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "costview",
    "splash": {
      "image": "./logo/logo3.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.costview.app"
    },
    "ios": {
      "bundleIdentifier": "com.costview.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "e481fa49-cce4-493b-969f-a14a5853e09d"
      }
    }
  }
}
