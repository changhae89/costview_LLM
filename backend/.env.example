# Supabase Project Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Supabase Project Settings > Database > Connection string (Transaction pooler)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres

# Supabase Project URL and public anon key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Comma-separated frontend origins allowed to call the backend API
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173,http://43.201.27.55:8081
